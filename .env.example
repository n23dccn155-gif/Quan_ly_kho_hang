# =========================================================================
# WMS LOGISTICS - HỆ THỐNG QUẢN LÝ KHO HÀNG
# FILE CẤU HÌNH MÔI TRƯỜNG MẪU (ROOT LEVEL)
# =========================================================================
#
# Dự án được chia thành 2 thư mục con độc lập: /backend và /frontend.
# Vui lòng copy file cấu hình này hoặc cấu hình trực tiếp tại:
#
# 1. Backend: /backend/.env.example -> /backend/.env
# 2. Frontend: /frontend/.env.example -> /frontend/.env
#
# =========================================================================

# -----------------
# 1. CẤU HÌNH BACKEND (Mẫu đầy đủ)
# -----------------
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# PORT=5001
# NODE_ENV=development
# JWT_SECRET="your-jwt-access-secret"
# JWT_REFRESH_SECRET="your-jwt-refresh-secret"
# CORS_ORIGIN="http://localhost:3000"
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT=587
# EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS="your-app-password"
# ADMIN_ALERT_EMAIL="admin@example.com"
# GEMINI_API_KEY="your-gemini-api-key"

# -----------------
# 2. CẤU HÌNH FRONTEND (Mẫu đầy đủ)
# -----------------
# NEXT_PUBLIC_API_URL="http://localhost:5001/api"
# BACKEND_URL="http://localhost:5001"
